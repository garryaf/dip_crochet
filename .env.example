# ============================================
# Cotcret (dip.crochet) — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================
# ANALYTICS & MARKETING
# ============================================

# Google Tag Manager Container ID (e.g., GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
# Note: If using GTM, GA4 should be configured inside GTM instead.
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook) Pixel ID (e.g., 1234567890)
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID (e.g., CXXXXXXXXXXXXXXXXX)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Microsoft Clarity Project ID (e.g., abcdefghij)
NEXT_PUBLIC_CLARITY_ID=

# ============================================
# SITE CONFIGURATION
# ============================================

# Base URL for the site (used for sitemap, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://dipcrochet-nine.vercel.app

# ============================================
# DATABASE (Sprint 3)
# ============================================

# PostgreSQL connection string
# Local: postgresql://postgres:postgres@localhost:5432/cotcret
# Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cotcret?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cotcret?schema=public"

# ============================================
# CMS (Sprint 3)
# ============================================

# Sanity Project ID
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=

# ============================================
# AUTH (Sprint 4)
# ============================================

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here-minimum-32-characters-long
AUTH_URL=http://localhost:3333

# OAuth Providers (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ============================================
# ERROR MONITORING (Sprint 6)
# ============================================

# Sentry DSN
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
